# ─────────────────────────────────────────────
def get_staged_diff() -> str:
    try:
        # -c core.quotepath=false → don't escape non-ASCII filenames
        result = run(
            ["git", "-c", "core.quotepath=false",
             "-c", "i18n.logOutputEncoding=UTF-8",
             "diff", "--cached"],
            capture=True
        )
        return (result.stdout or "").strip()
    except subprocess.CalledProcessError:
        return ""

def get_staged_files() -> list[str]:
    try:
        result = run(
            ["git", "-c", "core.quotepath=false",
             "diff", "--cached", "--name-only"],
            capture=True
        )
        return [f for f in (result.stdout or "").strip().splitlines() if f]
    except subprocess.CalledProcessError:
        return []

# ── provider implementations ─────────────────

def _call_openai_compat(base_url: str, api_key: str, model: str,
                         system: str, prompt: str) -> str:
    """Generic OpenAI-compatible /v1/chat/completions call (no SDK needed)."""
    import urllib.request, urllib.error
    payload = json.dumps({
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user",   "content": prompt},
        ],
        "temperature": 0.3,
        "max_tokens": 400,
    }).encode()
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/v1/chat/completions",
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        data = json.loads(resp.read())
    return data["choices"][0]["message"]["content"].strip()


def _call_anthropic(api_key: str, model: str, system: str, prompt: str) -> str:
    import urllib.request
    payload = json.dumps({
        "model": model,
        "max_tokens": 400,
        "system": system,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "Content-Type": "application/json",
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        data = json.loads(resp.read())
    return data["content"][0]["text"].strip()


def _call_ollama(base_url: str, model: str, system: str, prompt: str) -> str:
    import urllib.request
    payload = json.dumps({
        "model": model,
        "messages": [
            {"role": "system", "content": system},
            {"role": "user",   "content": prompt},
        ],
        "stream": False,
    }).encode()
    req = urllib.request.Request(
        f"{base_url.rstrip('/')}/api/chat",
        data=payload,
        headers={"Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=60) as resp:
        data = json.loads(resp.read())
    return data["message"]["content"].strip()


def call_ai(diff: str, files: list[str]) -> str:
    """Route to the correct provider based on AI_COMMIT_PROVIDER env var."""
    provider  = cfg("AI_COMMIT_PROVIDER", "openai").lower()
    max_chars = int(cfg("AI_COMMIT_DIFF_MAX_CHARS", "8000"))
    diff_snip = diff[:max_chars] + ("\n…[truncated]" if len(diff) > max_chars else "")

    SYSTEM = (
        "You are an expert software engineer. "
        "Given a git diff you MUST return ONLY a single Conventional Commit message "
        "with this exact format:\n\n"
        "<type>(<scope>): <short description>\n\n"
        "<body — 2-4 sentences explaining WHY, not WHAT>\n\n"
        "Rules:\n"
        "- type: feat|fix|docs|style|refactor|perf|test|chore|ci|build\n"
        "- scope: the module/file most affected (lowercase, no spaces)\n"
        "- short description: imperative mood, ≤72 chars, no period\n"
        "- body: optional but preferred\n"
        "- NO markdown, NO fences, NO extra commentary."
    )
    PROMPT = (
        f"Files changed: {', '.join(files) if files else 'unknown'}\n\n"
        f"Git diff:\n{diff_snip}"
    )

    info(f"AI provider: {provider}")

    try:
        if provider == "anthropic":
            api_key = cfg("ANTHROPIC_API_KEY") or die("ANTHROPIC_API_KEY not set")
            model   = cfg("AI_COMMIT_MODEL", "claude-3-5-haiku-20241022")
            return _call_anthropic(api_key, model, SYSTEM, PROMPT)

        elif provider == "ollama":
            base_url = cfg("OLLAMA_BASE_URL", "http://localhost:11434")
            model    = cfg("AI_COMMIT_MODEL", "llama3")
            return _call_ollama(base_url, model, SYSTEM, PROMPT)

        elif provider == "custom":
            base_url = cfg("AI_COMMIT_BASE_URL") or die("AI_COMMIT_BASE_URL not set")
            api_key  = cfg("AI_COMMIT_API_KEY", "nokey")
            model    = cfg("AI_COMMIT_MODEL", "gpt-4o-mini")
            return _call_openai_compat(base_url, api_key, model, SYSTEM, PROMPT)

        else:  # openai (default)
            api_key = cfg("OPENAI_API_KEY") or die("OPENAI_API_KEY not set")
            model   = cfg("AI_COMMIT_MODEL", "gpt-4o-mini")
            base_url = cfg("AI_COMMIT_BASE_URL", "https://api.openai.com")
            return _call_openai_compat(base_url, api_key, model, SYSTEM, PROMPT)

    except Exception as exc:
        die(f"AI call failed ({provider}): {exc}")


def phase_ai_commit() -> str:
    head("PHASE 2 · AI Commit Message Generation")

    diff  = get_staged_diff()
    files = get_staged_files()

    if not diff:
        die("Nothing staged. Run `git add <files>` first.", 3)

    info(f"Staged files: {', '.join(files)}")
    info("Sending diff to AI — please wait…")

    message = call_ai(diff, files)

    # basic sanity: must look like a conventional commit
    if not re.match(r"^\w+(\(.+\))?!?: .+", message):
        warn("AI response doesn't look like a Conventional Commit; using as-is.")

    print(f"\n{C.GREEN}{C.BOLD}Generated commit message:{C.RESET}")
    print(f"{C.WHITE}{'─'*55}")
    print(message)
    print(f"{'─'*55}{C.RESET}\n")

    # interactive confirmation
    if cfg("AI_COMMIT_NO_CONFIRM", "false").lower() != "true":
        answer = input(f"{C.YELLOW}Accept this message? [Y/n/e(dit)]: {C.RESET}").strip().lower()
        if answer == "n":
            die("Commit aborted by user.", 0)
        if answer == "e":
            import tempfile
            with tempfile.NamedTemporaryFile(mode="w", suffix=".txt",
                                             delete=False) as tf:
                tf.write(message)
                tf_name = tf.name
            editor = cfg("EDITOR", "vi" if not platform.system() == "Windows" else "notepad")
            os.system(f'{editor} "{tf_name}"')
            message = Path(tf_name).read_text().strip()
            os.unlink(tf_name)
            ok("Commit message updated.")

    return message

