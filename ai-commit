class C:
    RESET  = "\033[0m"
    BOLD   = "\033[1m"
    RED    = "\033[91m"
    GREEN  = "\033[92m"
    YELLOW = "\033[93m"
    BLUE   = "\033[94m"
    CYAN   = "\033[96m"
    WHITE  = "\033[97m"
    DIM    = "\033[2m"

def _p(color: str, icon: str, msg: str):
    print(f"{color}{C.BOLD}{icon}{C.RESET} {color}{msg}{C.RESET}")

def ok(msg):    _p(C.GREEN,  "✔", msg)
def err(msg):   _p(C.RED,    "✘", msg)
def warn(msg):  _p(C.YELLOW, "⚠", msg)
def info(msg):  _p(C.CYAN,   "→", msg)
def head(msg):  print(f"\n{C.BLUE}{C.BOLD}{'─'*55}\n  {msg}\n{'─'*55}{C.RESET}")

def die(msg: str, code: int = 1):
    err(msg)
    sys.exit(code)

# ─────────────────────────────────────────────
# 1. ENV LOADER  (.env cascade)
# ─────────────────────────────────────────────
def load_env():
    """Load .env files: project-local wins over global ~/.ai-commit/.env"""
    candidates = [
        Path.home() / ".ai-commit" / ".env",   # global defaults
        Path.cwd() / ".env",                    # project override
    ]
    # Only ASCII uppercase letters, digits and underscore are valid env var names
    valid_key = re.compile(r'^[A-Z][A-Z0-9_]*$')

    for env_file in candidates:
        if not env_file.exists():
            continue
        try:
            raw = env_file.read_text(encoding="utf-8-sig", errors="replace")
        except Exception:
            continue
        for line in raw.splitlines():
            # Strip BOM, whitespace, and any unicode decoration characters
            line = line.strip().lstrip('\ufeff')
            # Skip blank lines and comments
            if not line or line.startswith('#'):
                continue
            # Must contain = to be a key=value pair
            if '=' not in line:
                continue
            key, _, val = line.partition('=')
            key = key.strip()
            # Strip inline comments from value (e.g. key=value # comment)
            val = val.split('#')[0].strip().strip('"').strip("'")
            # Validate key: must be a proper env var name
            if not valid_key.match(key):
                continue
            # Don't overwrite already-set env vars (shell wins)
            if key not in os.environ:
                os.environ[key] = val

def cfg(key: str, default=None):
    return os.environ.get(key, default)

# ─────────────────────────────────────────────
# 2. SHELL RUNNER
# ─────────────────────────────────────────────
def run(cmd, capture=False, check=True, shell=False):
    """Run a command; return CompletedProcess. Always UTF-8 safe."""
    if isinstance(cmd, str) and not shell:
        cmd = cmd.split()
    kwargs = dict(
        capture_output=capture,
        text=True,
        encoding="utf-8",
        errors="replace",      # never crash on unknown bytes
        shell=shell,
        env=os.environ,
    )
    result = subprocess.run(cmd, **kwargs)
    if check and result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, cmd,
                                            result.stdout, result.stderr)
    return result

def run_ok(cmd, shell=False) -> bool:
    """Return True if command exits 0."""
    try:
        run(cmd, check=True, shell=shell)
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False

def cmd_exists(name: str) -> bool:
    import shutil
    return shutil.which(name) is not None

# ─────────────────────────────────────────────
# 3. PHASE 1 — QUALITY VALIDATION
# ─────────────────────────────────────────────
def phase_quality():
    head("PHASE 1 · Quality Validation (Tests & Linting)")

    skip = cfg("AI_COMMIT_SKIP_QUALITY", "false").lower() == "true"
    if skip:
        warn("AI_COMMIT_SKIP_QUALITY=true — skipping quality phase")
        return

    # ── detect project type ──────────────────
    cwd = Path.cwd()
    errors = []

    # Node / JS / TS
    if (cwd / "package.json").exists():
        pkg = json.loads((cwd / "package.json").read_text())
        scripts = pkg.get("scripts", {})

        # linting
        linter_cmd = cfg("AI_COMMIT_LINT_CMD")
        if linter_cmd:
            info(f"Running linter: {linter_cmd}")
        elif "lint" in scripts:
            linter_cmd = "npm run lint"
            info("Running: npm run lint")
        elif cmd_exists("eslint"):
            linter_cmd = "eslint ."
            info("Running: eslint .")
        else:
            warn("No linter found — set AI_COMMIT_LINT_CMD in .env to override")

        if linter_cmd:
            try:
                run(linter_cmd, shell=True)
                ok("Linter passed")
            except subprocess.CalledProcessError:
                errors.append("Linter failed. Fix errors before committing.")

        # tests
        test_cmd = cfg("AI_COMMIT_TEST_CMD")
        if test_cmd:
            info(f"Running tests: {test_cmd}")
        elif "test" in scripts:
            test_cmd = "npm test -- --watchAll=false"
            info("Running: npm test")
        elif cmd_exists("jest"):
            test_cmd = "jest --passWithNoTests"

        if test_cmd:
            try:
                run(test_cmd, shell=True)
                ok("Tests passed")
            except subprocess.CalledProcessError:
                errors.append("Unit tests FAILED. Fix before committing.")

    # Python
    elif (cwd / "pyproject.toml").exists() or (cwd / "setup.py").exists() \
            or list(cwd.glob("*.py")):
        linter_cmd = cfg("AI_COMMIT_LINT_CMD")
        test_cmd   = cfg("AI_COMMIT_TEST_CMD")

        if not linter_cmd:
            if cmd_exists("ruff"):   linter_cmd = "ruff check ."
            elif cmd_exists("flake8"): linter_cmd = "flake8 ."
        if not test_cmd:
            if cmd_exists("pytest"): test_cmd = "pytest --tb=short -q"

        for label, cmd_ in [("Linter", linter_cmd), ("Tests", test_cmd)]:
            if cmd_:
                info(f"Running {label}: {cmd_}")
                try:
                    run(cmd_, shell=True)
                    ok(f"{label} passed")
                except subprocess.CalledProcessError:
                    errors.append(f"{label} FAILED.")
            else:
                warn(f"No {label.lower()} detected — set AI_COMMIT_LINT_CMD / AI_COMMIT_TEST_CMD")

    else:
        # generic fallback
        custom_test = cfg("AI_COMMIT_TEST_CMD")
        custom_lint = cfg("AI_COMMIT_LINT_CMD")
        if custom_test:
            try:
                run(custom_test, shell=True)
                ok("Custom test command passed")
            except subprocess.CalledProcessError:
                errors.append("Custom test command FAILED.")
        if custom_lint:
            try:
                run(custom_lint, shell=True)
                ok("Custom lint command passed")
            except subprocess.CalledProcessError:
                errors.append("Custom lint command FAILED.")
        if not custom_test and not custom_lint:
            warn("No test/lint detected. Set AI_COMMIT_TEST_CMD / AI_COMMIT_LINT_CMD")

    if errors:
        for e in errors:
            err(e)
        die("Quality phase FAILED — commit aborted.", 2)

    ok("All quality checks passed ✓")

