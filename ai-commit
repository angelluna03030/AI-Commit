# ── Force UTF-8 everywhere on Windows ──────────────────────
# Must happen before any subprocess or print call
if platform.system() == "Windows" or os.environ.get("MSYSTEM"):
    os.environ["PYTHONIOENCODING"] = "utf-8"
    os.environ["PYTHONUTF8"] = "1"
    # Git: force diff output in UTF-8
    os.environ.setdefault("GIT_TERMINAL_PROMPT", "0")
    os.environ["LC_ALL"] = "C.UTF-8"
    try:
        # Reconfigure stdout/stderr to UTF-8 (Python 3.7+)
        sys.stdout.reconfigure(encoding="utf-8", errors="replace")
        sys.stderr.reconfigure(encoding="utf-8", errors="replace")
    except AttributeError:
        pass

# ─────────────────────────────────────────────
# 0. COLOUR HELPERS  (work on all platforms)
# ─────────────────────────────────────────────
if platform.system() == "Windows" and "WT_SESSION" not in os.environ:
    try:
        import ctypes
        ctypes.windll.kernel32.SetConsoleMode(
            ctypes.windll.kernel32.GetStdHandle(-11), 7)
    except Exception:
