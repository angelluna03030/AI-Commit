# Patterns that suggest leaked secrets
SECRET_PATTERNS = [
    (r'(?i)(api[_-]?key|apikey)\s*[:=]\s*["\']?[A-Za-z0-9_\-]{16,}',
     "Possible API key"),
    (r'(?i)(secret|password|passwd|pwd)\s*[:=]\s*["\']?\S{8,}',
     "Possible password/secret"),
    (r'(?i)aws[_-]?(access[_-]?key[_-]?id|secret[_-]?access[_-]?key)\s*[:=]\s*\S+',
     "AWS credential"),
    (r'(?i)(sk|pk)-(live|test)-[A-Za-z0-9]{24,}',
     "Stripe key"),
    (r'eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+',
     "JWT token"),
    (r'-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----',
     "Private key"),
    (r'ghp_[A-Za-z0-9]{36}',
     "GitHub Personal Access Token"),
    (r'xox[baprs]-[A-Za-z0-9\-]+',
     "Slack token"),
]

def scan_secrets(files: list[str]) -> list[str]:
    issues = []
    for fpath in files:
        p = Path(fpath)
        if not p.exists() or p.stat().st_size > 500_000:
            continue
        try:
            content = p.read_text(encoding="utf-8", errors="ignore")
        except Exception:
            continue
        for pattern, label in SECRET_PATTERNS:
            if re.search(pattern, content):
                issues.append(f"{label} detected in {fpath}")
    return issues

def phase_production_ready():
    head("PHASE 3 · Production-Ready Check (Security & Build)")

    skip_sec = cfg("AI_COMMIT_SKIP_SECURITY", "false").lower() == "true"
    if skip_sec:
        warn("AI_COMMIT_SKIP_SECURITY=true — skipping security scan")
    else:
        # CORREGIDO: Eliminadas las anotaciones
        staged_diff = get_staged_diff() 
        files = get_staged_files()
        info(f"Scanning staged changes for exposed secrets…")
        
        issues = scan_secrets(files)

        # FIXED: Use re.search directly without any() for a single string
        security_pattern = r'(?i)api_key|password|secret|token|sk-live|ghp_'
        if re.search(security_pattern, staged_diff):
            issues.append("Sensitive patterns detected in the staged diff.")

        # External Tool: Gitleaks (Safe Execution)
        if cmd_exists("gitleaks"):
            info("Running gitleaks…")
            # shell=False is used for security
            if not run_ok(["gitleaks", "protect", "--staged", "-v"], shell=False):
                issues.append("Gitleaks detected potential secrets.")

        if issues:
            for i in issues: err(i)
            if cfg("AI_COMMIT_STRICT_SECURITY", "true").lower() == "true":
                die("Security check FAILED. Commit aborted to prevent leaks.", 4)
        else:
            ok("No secrets detected ✓")

    # --- Build Section ---
    if cfg("AI_COMMIT_SKIP_BUILD", "false").lower() == "true":
        warn("AI_COMMIT_SKIP_BUILD=true — skipping build")
        return

    build_cmd = cfg("AI_COMMIT_BUILD_CMD")
    if build_cmd:
        info(f"Running build: {build_cmd}")
        try:
            # SAFE: split command string into arguments list
            import shlex
            build_args = shlex.split(build_cmd)
            run(build_args, shell=False, capture=True)
            ok("Build succeeded ✓")
        except subprocess.CalledProcessError as e:
            print(f"{C.RED}{e.stderr}{C.RESET}")
            die("Build FAILED — fix errors before pushing.", 5)

def get_clean_diff() -> str:
    # Filter out lockfiles and binary-like assets from the diff
    cmd = [
        "git", "diff", "--cached", 
        "--", ":!*-lock.json", ":!*.lock", ":!*.svg", ":!*.png"
    ]
    result = run(cmd, capture=True)
    return result.stdout.strip()            
# ─────────────────────────────────────────────
# 6. PHASE 4 — GIT COMMIT & PUSH
# ─────────────────────────────────────────────
def get_current_branch() -> str:
    try:
        result = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], capture=True)
        return (result.stdout or "main").strip()
    except subprocess.CalledProcessError:
        return "main"


def phase_git(commit_message: str, args):
    head("PHASE 4 · Git Commit & Push")

    branch = get_current_branch()
    push_target = cfg("AI_COMMIT_PUSH_REMOTE", "origin")

    # commit
    info(f"Creating commit on branch '{branch}' …")
    try:
        run(["git", "commit", "-m", commit_message])
        ok("Commit created ✓")
    except subprocess.CalledProcessError as exc:
        die(f"git commit failed: {exc.stderr}", 6)

    # push
    if args.no_push or cfg("AI_COMMIT_NO_PUSH", "false").lower() == "true":
        warn("Push skipped (--no-push or AI_COMMIT_NO_PUSH=true)")
        return

    info(f"Pushing to {push_target}/{branch} …")
    push_flags = cfg("AI_COMMIT_PUSH_FLAGS", "").split()
    cmd_ = ["git", "push", push_target, branch] + push_flags
    try:
        run(cmd_)
        ok(f"Pushed to {push_target}/{branch} ✓")
    except subprocess.CalledProcessError as exc:
        die(f"git push failed: {exc.stderr}", 7)

# ─────────────────────────────────────────────
# 7. ENTRY POINT
# ─────────────────────────────────────────────
def parse_args():
    p = argparse.ArgumentParser(
        prog="ai-commit",
        description="AI-powered Git workflow: quality → AI commit → security → push",
    )
    p.add_argument("--no-push",      action="store_true",
                   help="Skip git push after commit")
    p.add_argument("--no-quality",   action="store_true",
                   help="Skip tests/linting phase")
    p.add_argument("--no-security",  action="store_true",
                   help="Skip security scan")
    p.add_argument("--no-build",     action="store_true",
                   help="Skip build check")
    p.add_argument("--dry-run",      action="store_true",
                   help="Run all phases but skip git commit/push")
    p.add_argument("--provider",
                   help="Override AI_COMMIT_PROVIDER (openai|anthropic|ollama|custom)")
    return p.parse_args()


def main():
    load_env()
    args = parse_args()

    # CLI overrides
    if args.no_quality:  os.environ["AI_COMMIT_SKIP_QUALITY"]  = "true"
    if args.no_security: os.environ["AI_COMMIT_SKIP_SECURITY"] = "true"
    if args.no_build:    os.environ["AI_COMMIT_SKIP_BUILD"]    = "true"
    if args.provider:    os.environ["AI_COMMIT_PROVIDER"]      = args.provider

    print(f"\n{C.CYAN}{C.BOLD}"
          f"╔══════════════════════════════════════╗\n"
          f"║        AI-COMMIT  v1.0               ║\n"
          f"║  Quality · AI · Security · Push      ║\n"
          f"╚══════════════════════════════════════╝{C.RESET}\n")

    # verify we're inside a git repo
    if not run_ok(["git", "rev-parse", "--is-inside-work-tree"], shell=False):
        die("Not inside a git repository.", 1)

    phase_quality()
    commit_msg = phase_ai_commit()
    phase_production_ready()

    if args.dry_run:
        warn("--dry-run: skipping git commit and push")
        print(f"\n{C.GREEN}{C.BOLD}✔ Dry-run complete. Commit message ready:{C.RESET}")
        print(commit_msg)
        return

    phase_git(commit_msg, args)

    print(f"\n{C.GREEN}{C.BOLD}{'═'*45}")
    print("  🚀  All phases passed — code shipped!")
    print(f"{'═'*45}{C.RESET}\n")


if __name__ == "__main__":
    main()
